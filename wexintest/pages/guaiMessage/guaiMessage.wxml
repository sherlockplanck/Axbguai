<view class="page">
  <view class="header">
    <view class="title">云端消息</view>
    <view class="subtitle">属性：guai_message</view>
  </view>

  <view class="status-bar">
    <text>最近更新：{{lastUpdate}}</text>
    <text wx:if="{{loading}}">读取中</text>
  </view>

  <view wx:if="{{errorMessage}}" class="error">{{errorMessage}}</view>

  <view class="message-card">
    <view class="card-title">消息内容</view>
    <view wx:if="{{isEmpty}}" class="empty">暂无云端消息</view>
    <view wx:else class="message-text">{{guaiMessage}}</view>
    <view class="count">{{messageLength}} / 128</view>
  </view>

  <view class="button-row">
    <button class="refresh-button" loading="{{loading}}" disabled="{{loading}}" bindtap="fetchGuaiMessage">
      刷新
    </button>
    <button class="clear-button" loading="{{clearing}}" disabled="{{clearing}}" bindtap="confirmClearMessage">
      清空云端消息
    </button>
  </view>
</view>
