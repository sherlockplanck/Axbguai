page {
  min-height: 100vh;
  background: #eef3f5;
  color: #1f2933;
}

.page {
  min-height: 100vh;
  padding-bottom: 32rpx;
  box-sizing: border-box;
}

.map {
  width: 100%;
  height: 62vh;
}

.panel {
  margin: 24rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(27, 43, 65, 0.08);
}

.panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle,
.loading,
.empty,
.track-coord {
  color: #607080;
  font-size: 24rpx;
}

.subtitle {
  margin-top: 8rpx;
}

.error {
  margin-bottom: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #b42318;
  font-size: 24rpx;
}

.location {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  word-break: break-all;
}

.track-title {
  margin: 24rpx 0 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.track-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #e5ecf1;
}

.track-index {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #e4f3f5;
  color: #1f7a8c;
  font-size: 24rpx;
  font-weight: 700;
}

.track-body {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
}

@media (max-width: 360px) {
  .location {
    grid-template-columns: 1fr;
  }
}
