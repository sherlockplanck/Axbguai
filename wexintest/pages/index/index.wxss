page {
  min-height: 100vh;
  background: #f4f7f9;
  color: #1f2933;
}

.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 64rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  margin-top: 8rpx;
  color: #607080;
  font-size: 26rpx;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
  color: #607080;
  font-size: 24rpx;
}

.error {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #b42318;
  font-size: 24rpx;
}

.action-row {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.action-button {
  width: 100%;
  margin: 0;
  border-radius: 8rpx;
  background: #1f7a8c;
  color: #ffffff;
  font-size: 28rpx;
}

.metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.metric {
  min-height: 248rpx;
  padding: 28rpx 16rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(27, 43, 65, 0.08);
  text-align: center;
  box-sizing: border-box;
}

.metric-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: #e8f5ef;
  color: #007a4d;
  font-size: 34rpx;
  font-weight: 700;
}

.metric-alert .metric-icon {
  background: #fff1f2;
  color: #b42318;
}

.metric-value {
  min-height: 52rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
  word-break: break-all;
}

.metric-label {
  margin-top: 10rpx;
  color: #607080;
  font-size: 24rpx;
}

.message-panel {
  margin-top: 36rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(27, 43, 65, 0.08);
}

.panel-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.message-input {
  width: 100%;
  min-height: 180rpx;
  padding: 22rpx;
  border: 1rpx solid #d8e0e7;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #111827;
  font-size: 28rpx;
  box-sizing: border-box;
}

.send-button {
  margin-top: 24rpx;
  border-radius: 8rpx;
  background: #00a86b;
  color: #ffffff;
  font-size: 30rpx;
}

.send-button[disabled] {
  background: #8ccdb4;
  color: #ffffff;
}

@media (max-width: 360px) {
  .metrics {
    grid-template-columns: 1fr;
  }

}
