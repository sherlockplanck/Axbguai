page {
  min-height: 100vh;
  background: #f4f7f9;
  color: #1f2933;
}

.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 64rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  margin-top: 8rpx;
  color: #607080;
  font-size: 26rpx;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
  color: #607080;
  font-size: 24rpx;
}

.error {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #b42318;
  font-size: 24rpx;
}

.notice {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
  background: #e8f5ef;
  color: #007a4d;
  font-size: 24rpx;
}

.contact-card,
.priority-panel {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(27, 43, 65, 0.08);
}

.card-title,
.panel-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d8e0e7;
  border-radius: 8rpx;
  background: #f8fafc;
  box-sizing: border-box;
  font-size: 28rpx;
}

.input-spaced {
  margin-top: 18rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #e5ecf1;
}

.info-row:first-of-type {
  border-top: 0;
}

.info-label {
  width: 88rpx;
  color: #607080;
  font-size: 26rpx;
}

.info-value,
.info-empty {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  line-height: 1.4;
  word-break: break-all;
}

.info-empty {
  color: #9aa8b4;
}

.priority-row {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.priority-button {
  width: 100%;
  margin: 0;
  border-radius: 8rpx;
  background: #e4eef2;
  color: #1f2933;
  font-size: 28rpx;
}

.priority-button.active {
  background: #1f7a8c;
  color: #ffffff;
}

.priority-button[disabled] {
  color: #1f2933;
}

.submit-button {
  margin-top: 8rpx;
  border-radius: 8rpx;
  background: #00a86b;
  color: #ffffff;
  font-size: 30rpx;
}

.edit-button {
  margin-top: 8rpx;
  border-radius: 8rpx;
  background: #1f7a8c;
  color: #ffffff;
  font-size: 30rpx;
}

.submit-button[disabled] {
  background: #8ccdb4;
  color: #ffffff;
}
