page {
  min-height: 100vh;
  background: #f4f7f9;
  color: #1f2933;
}

.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 64rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  margin-top: 8rpx;
  color: #607080;
  font-size: 26rpx;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
  color: #607080;
  font-size: 24rpx;
}

.error {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #b42318;
  font-size: 24rpx;
}

.message-card {
  min-height: 320rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(27, 43, 65, 0.08);
  box-sizing: border-box;
}

.card-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.message-text,
.empty {
  min-height: 170rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-all;
  white-space: pre-wrap;
}

.empty,
.count {
  color: #607080;
}

.count {
  margin-top: 18rpx;
  text-align: right;
  font-size: 24rpx;
}

.button-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 28rpx;
}

.refresh-button,
.clear-button {
  width: 100%;
  margin: 0;
  border-radius: 8rpx;
  color: #ffffff;
  font-size: 28rpx;
}

.refresh-button {
  background: #1f7a8c;
}

.clear-button {
  background: #b42318;
}

.refresh-button[disabled],
.clear-button[disabled] {
  color: #ffffff;
  opacity: 0.7;
}

@media (max-width: 360px) {
  .button-row {
    grid-template-columns: 1fr;
  }
}
